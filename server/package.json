    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.6",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
