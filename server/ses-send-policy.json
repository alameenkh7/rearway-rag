{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["ses:SendEmail", "ses:SendRawEmail"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "ses:FromAddress": "onboarding@resolve.rearway.com"
        },
        "StringLike": {
          "aws:SourceArn": "arn:aws:ses:ap-south-1:*:identity/resolve.rearway.com"
        }
      }
    }
  ]
}
