PORT=4001
NODE_ENV=development

# Postgres — local dev points at the docker-compose service; production points at Neon.
# Same variable name in both cases, only the value changes.
DATABASE_URL=postgres://resolve:resolve_dev_password@localhost:5434/resolve_rag_dev

# Set to "true" for any managed/remote Postgres that requires an encrypted
# connection (Neon, RDS, this deploy's own resolverag server, etc). Leave
# unset/false for the local docker-compose Postgres. Independent of NODE_ENV —
# do not use NODE_ENV=production just to get SSL, set this instead.
DATABASE_SSL=false

# OpenRouter (embeddings + chat completions)
OPENROUTER_API_KEY=sk-or-v1-...

# Resend (OTP emails)
RESEND_API_KEY=re_...
EMAIL_FROM=Resolve <onboarding@resend.dev>

# Auth
AUTH_JWT_SECRET=change-me-to-a-long-random-string

WIDGET_HOST_URL=http://localhost:4001/widget
